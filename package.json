{
  "name": "baby-list",
  "version": "3.2.1",
  "private": true,
  "type": "module",
  "description": "Newborn Essentials checklist PWA + push sender",
  "scripts": {
    "check": "node scripts/check-html.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run check && npm test",
    "push": "node scripts/send-push.mjs",
    "vapid": "node scripts/generate-vapid.mjs",
    "serve": "node scripts/serve.mjs",
    "css": "tailwindcss -i assets/input.css -o assets/app.css --minify"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.18",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "web-push": "^3.6.7"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "canvas-confetti": "^1.9.4"
  }
}
